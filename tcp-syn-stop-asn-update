#!/bin/sh
# tcp-syn-stop-asn-update — download and import ASN + RIR delegation databases
set -eu

ASN_URL="https://iptoasn.com/data/ip2asn-v4.tsv.gz"
INSTALL_DIR="/opt/tcp_syn_stop"
TSV_FILE="${INSTALL_DIR}/ip2asn-v4.tsv"
RIR_DIR="${INSTALL_DIR}/rir"
INTEL="${INSTALL_DIR}/syn-intel"

log() { logger -t tcp-syn-stop-asn-update "$@"; echo "$@"; }

# ── Phase 1: ip2asn (BGP-origin ASN data) ────────────────────────────

tmp=$(mktemp "${TSV_FILE}.XXXXXX")
trap 'rm -f "$tmp"' EXIT

log "Downloading ${ASN_URL}..."
if ! curl -fsSL --retry 3 --retry-delay 10 "$ASN_URL" | gunzip > "$tmp"; then
    log "ERROR: ASN download failed"
    exit 1
fi

# Sanity check: file should have >400k lines (current data ~515k)
lines=$(wc -l < "$tmp")
if [ "$lines" -lt 400000 ]; then
    log "ERROR: downloaded file has only ${lines} lines (expected >400k); aborting"
    exit 1
fi

mv -f "$tmp" "$TSV_FILE"
trap - EXIT
log "Downloaded ${lines} ASN ranges."

log "Importing ASN data into SQLite..."
"$INTEL" --import-asn "$TSV_FILE"

# ── Phase 2: RIR delegation files (authoritative registration) ───────

mkdir -p "$RIR_DIR"
rir_ok=0
rir_fail=0

for rir in ripencc arin apnic lacnic afrinic; do
    case "$rir" in
        ripencc) host="ftp.ripe.net/pub/stats/ripencc" ;;
        arin)    host="ftp.arin.net/pub/stats/arin" ;;
        apnic)   host="ftp.apnic.net/stats/apnic" ;;
        lacnic)  host="ftp.lacnic.net/pub/stats/lacnic" ;;
        afrinic) host="ftp.afrinic.net/pub/stats/afrinic" ;;
    esac
    url="https://${host}/delegated-${rir}-extended-latest"
    dest="${RIR_DIR}/delegated-${rir}-extended-latest"

    log "Downloading RIR: ${rir}..."
    if curl -fsSL --retry 3 --retry-delay 10 "$url" -o "$dest"; then
        rir_ok=$((rir_ok + 1))
    else
        log "WARNING: failed to fetch ${rir} delegation file"
        rir_fail=$((rir_fail + 1))
    fi
done

if [ "$rir_ok" -gt 0 ]; then
    log "Importing RIR delegations into SQLite (${rir_ok}/5 files)..."
    "$INTEL" --import-rir "$RIR_DIR"
else
    log "ERROR: all RIR downloads failed; skipping import"
fi

# ── Fix permissions ───────────────────────────────────────────────────

chgrp tcp_syn_stop "${INSTALL_DIR}/ip2asn.db" 2>/dev/null || true
chmod g+rw "${INSTALL_DIR}/ip2asn.db" 2>/dev/null || true

log "Database update complete (ASN: ok, RIR: ${rir_ok}/5 fetched, ${rir_fail} failed)."
